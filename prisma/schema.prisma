generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  specs       String   // Will store JSON string for specifications
  sizes       String   @default("[]") // Will store JSON string array for sizes
  images      String   // Will store JSON string (array of image URLs)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default("global")
  primaryEmail    String?
  primaryPhone    String?
  addressText     String?
  googleMapsEmbed String?
  contactCards    String?  // Will store JSON string array of { heading: string, email: string, phone: string }
  updatedAt       DateTime @updatedAt
}
